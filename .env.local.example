# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose this client-side

# ── Resend ────────────────────────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Inbound webhook secret (set this in Resend inbound settings, then copy here)
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# The domain used for inbound email routing
# Set up MX records on inbound.wintheweek.co pointing to Resend's inbound servers
INBOUND_EMAIL_DOMAIN=inbound.wintheweek.co

# The "from" address for outgoing campaign emails
FROM_EMAIL=hello@wintheweek.co
FROM_NAME=Win the Week

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron security ─────────────────────────────────────────────────────────────
# A random secret used to authenticate cron job calls to /api/send-weekly
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ── Encryption ───────────────────────────────────────────────────────────
# Used to encrypt sensitive data at rest (e.g., Slack tokens)
# Generate with: openssl rand -hex 32
# If not set, tokens are stored in plaintext (acceptable for dev)
ENCRYPTION_KEY=your-encryption-key-here
